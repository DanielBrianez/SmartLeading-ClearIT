# ─── Google Gemini AI ────────────────────────────────────────────────────────
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# ─── Banco de Dados PostgreSQL Serverless (Supabase) ─────────────────────────
# Como obter a DATABASE_URL:
#   1. Acesse https://supabase.com e crie uma conta (gratuito)
#   2. Crie um novo projeto (escolha a região mais próxima — ex: São Paulo)
#   3. Vá em: Project Settings → Database → Connection String → URI
#   4. Clique em "URI" e copie a string de conexão
#   5. Substitua [YOUR-PASSWORD] pela senha que você definiu ao criar o projeto
#
# Formato: postgresql://postgres:[SENHA]@db.[REF-DO-PROJETO].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO_REF.supabase.co:5432/postgres